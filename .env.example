# =====================================================
# CryptoPulse - Environment Configuration
# Copy this file to .env and adjust values as needed.
# Do NOT commit .env to git (it is in .gitignore).
# =====================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=cryptopulse
POSTGRES_PASSWORD=cryptopulse_dev_password
POSTGRES_DB=cryptopulse
AIRFLOW_DB=cryptopulse_airflow
POSTGRES_PORT=5433

# ---------- pgAdmin ----------
PGADMIN_DEFAULT_EMAIL=admin@cryptopulse.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# ---------- Airflow ----------
AIRFLOW_UID=50000
AIRFLOW_WEBSERVER_PORT=8088
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
# To generate a new Fernet key:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ---------- Elasticsearch ----------
ELASTICSEARCH_PORT=9200
# Lower heap size keeps the stack usable on a 16 GB student laptop.
ES_JAVA_OPTS="-Xms512m -Xmx512m"

# ---------- Kibana ----------
KIBANA_PORT=5601

# ---------- Pipeline configuration ----------
# DATA_MODE=live    -> fetch from Binance API and RSS feeds
# DATA_MODE=sample  -> read from data/sample/ (offline / demo fallback)
DATA_MODE=live

# Comma-separated list of Binance trading pairs to ingest.
CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,ADAUSDT

# Comma-separated list of RSS feed URLs.
NEWS_RSS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss,https://cointelegraph.com/rss

# Z-score threshold for flagging price anomalies.
ZSCORE_THRESHOLD=2.5

# Rolling window size (in minutes) used to compute mean and std for z-score.
ZSCORE_WINDOW_MINUTES=60

# Time window (in minutes) around an anomaly to look for related news.
NEWS_LINK_WINDOW_MINUTES=30
